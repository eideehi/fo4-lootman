{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "packaging/scripts/**/*.ts",
    "packaging/tests/**/*.ts",
    "tools/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "packaging/build", "packaging/dist", "dist"]
}
